{
  "openapi": "3.0.3",
  "info": {
    "title": "Stripe Account Credential Demo",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.stripe.com"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/account": {
      "get": {
        "operationId": "stripeAccount",
        "summary": "Read Stripe account using a selected Daptin credential",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stripe account"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}

