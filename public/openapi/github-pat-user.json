{
  "openapi": "3.0.3",
  "info": {
    "title": "GitHub PAT User Demo",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.github.com"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/user": {
      "get": {
        "operationId": "githubPatUser",
        "summary": "Read the authenticated GitHub user using a selected Daptin credential",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Negative-test input. Daptin must ignore this and use the selected credential_id."
          }
        ],
        "responses": {
          "200": {
            "description": "Authenticated GitHub profile"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}

