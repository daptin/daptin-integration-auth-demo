DAPTIN_BASE_URL=http://localhost:7336
DAPTIN_HOST_PORT=7336
DAPTIN_IMAGE=daptin/daptin:v0.12.2
DAPTIN_RELEASE_TAG=latest

DAPTIN_ADMIN_EMAIL=admin@example.com
DAPTIN_ADMIN_PASSWORD=adminadmin

DEMO_ALICE_EMAIL=alice@example.com
DEMO_ALICE_PASSWORD=alice-password
DEMO_BOB_EMAIL=bob@example.com
DEMO_BOB_PASSWORD=bob-password

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Value stored in Daptin oauth_connect. Daptin appends ?authenticator=github-e2e.
DAPTIN_OAUTH_REDIRECT_URI=http://localhost:7336/oauth/response
# Value configured in the GitHub OAuth app.
GITHUB_OAUTH_CALLBACK_URL=http://localhost:7336/oauth/response?authenticator=github-e2e

# Optional. If set, setup creates credential rows owned by Alice/Bob.
ALICE_GITHUB_PAT=
BOB_GITHUB_PAT=
STRIPE_SECRET_KEY=
